// Schéma Prisma : uniquement des données persistantes (jamais l'état d'une partie en cours).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Compte utilisateur persistant (V2).
model User {
  id           String               @id @default(uuid())
  username     String               @unique
  passwordHash String
  createdAt    DateTime             @default(now())
  gamePlayers  FinishedGamePlayer[]
}

/// Une partie terminée, conservée pour l'historique et les statistiques.
model FinishedGame {
  id         String               @id @default(uuid())
  code       String
  rounds     Int
  winnerId   String
  winnerName String
  createdAt  DateTime             @default(now())
  players    FinishedGamePlayer[]
}

/// Score final d'un joueur dans une partie terminée.
model FinishedGamePlayer {
  id       String        @id @default(uuid())
  gameId   String
  playerId String
  name     String
  score    Int
  /// Lien vers le compte utilisateur si le joueur était authentifié.
  userId   String?
  game     FinishedGame  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user     User?         @relation(fields: [userId], references: [id])
}
